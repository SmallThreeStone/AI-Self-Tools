<view class="page {{themeClass}}">
  <!-- ===== 状态：训练中 ===== -->
  <block wx:if="{{state === 'active'}}">
    <!-- 顶部进度 -->
    <view class="training-header">
      <text class="training-title">自由训练</text>
      <text class="training-progress">已完成 {{completedSets}} 组，总容量 {{totalVolume}} kg</text>
    </view>

    <!-- 建议动作 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">建议动作</text>
        <text class="section-link" bindtap="openSearch">搜索更多 ›</text>
      </view>
      <scroll-view class="suggest-scroll" scroll-x enable-flex>
        <view class="suggest-chip" wx:for="{{suggestedExercises}}" wx:key="*this" data-name="{{item}}" bindtap="addExercise">
          <text class="chip-text">{{item}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- 已选动作列表 -->
    <view class="section" wx:if="{{exercises.length > 0}}">
      <view class="section-header">
        <text class="section-title">已选动作 ({{exercises.length}})</text>
      </view>
      <view class="exercise-list">
        <view class="exercise-item {{currentExerciseIdx === idx ? 'active' : ''}}" wx:for="{{exercises}}" wx:key="idx" data-idx="{{idx}}" bindtap="switchExercise">
          <view class="exercise-info">
            <text class="exercise-name">{{item.exerciseName}}</text>
            <text class="exercise-meta">{{item.muscleGroup}} · {{item.sets.length}}组</text>
          </view>
          <view class="exercise-actions">
            <text class="badge-current" wx:if="{{currentExerciseIdx === idx}}">当前</text>
            <text class="btn-remove" data-idx="{{idx}}" bindtap="removeExercise">✕</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 当前动作录入 -->
    <view class="section" wx:if="{{exercises.length > 0}}">
      <view class="section-header">
        <text class="section-title">{{exercises[currentExerciseIdx].exerciseName}}</text>
        <text class="exercise-count">{{currentExerciseIdx+1}}/{{exercises.length}}</text>
      </view>

      <view class="sets-list">
        <view class="set-row header">
          <text class="set-col">组号</text>
          <text class="set-col">重量(kg)</text>
          <text class="set-col">次数</text>
          <text class="set-col">备注</text>
        </view>
        <view class="set-row" wx:for="{{exercises[currentExerciseIdx].sets}}" wx:for-index="sIdx" wx:key="*this">
          <text class="set-col">{{sIdx + 1}}</text>
          <text class="set-col">{{item.weight}}</text>
          <text class="set-col">{{item.reps}}</text>
          <text class="set-col">{{item.note || '-'}}</text>
        </view>
      </view>

      <view class="input-row">
        <input class="set-input weight" type="digit" placeholder="重量" value="{{weightInput}}" bindinput="onWeightInput" />
        <text class="input-x">×</text>
        <input class="set-input reps" type="digit" placeholder="次数" value="{{repsInput}}" bindinput="onRepsInput" />
        <input class="set-input note" placeholder="备注" value="{{noteInput}}" bindinput="onNoteInput" />
      </view>

      <button class="btn-add" bindtap="addSet">✓ 完成本组</button>
      <button class="btn-finish" bindtap="finishWorkout">✓ 结束训练</button>
    </view>

    <!-- 空状态 -->
    <view class="empty-section" wx:if="{{exercises.length === 0}}">
      <text class="empty-text">点击上方建议动作开始训练</text>
    </view>
  </block>

  <!-- ===== 状态：搜索弹层 ===== -->
  <block wx:if="{{showSearch}}">
    <view class="mask" bindtap="closeSearch"></view>
    <view class="search-panel">
      <view class="search-header">
        <input class="search-input" placeholder="搜索动作..." value="{{searchKeyword}}" bindinput="onSearchInput" focus="true" />
        <text class="search-cancel" bindtap="closeSearch">取消</text>
      </view>
      <view class="search-results" wx:if="{{searchResults.length > 0}}">
        <view class="search-item" wx:for="{{searchResults}}" wx:key="id" data-name="{{item.name}}" bindtap="selectSearchResult">
          <text class="search-name">{{item.name}}</text>
          <text class="search-muscle">{{item.muscleGroup}}</text>
        </view>
      </view>
      <view class="empty" wx:if="{{searchKeyword && searchResults.length === 0}}">未找到匹配动作</view>
    </view>
  </block>

  <!-- ===== 状态：训练完成 ===== -->
  <block wx:elif="{{state === 'completed'}}">
    <view class="completed-view">
      <text class="completed-icon">✅</text>
      <text class="completed-title">训练已保存</text>
      <text class="completed-meta">完成 {{completedSets}} 组 · 总容量 {{totalVolume}} kg</text>
      <button class="btn-new" bindtap="newWorkout">开始新训练</button>
    </view>
  </block>
</view>
