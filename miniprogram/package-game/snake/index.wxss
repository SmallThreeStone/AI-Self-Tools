.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.hud {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.hud-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.hud-score,
.hud-high {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.num {
  color: var(--text-primary);
  font-weight: 600;
}

.hud-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.mini.ghost {
  margin: 0;
  padding: 0 20rpx;
  line-height: 52rpx;
  background: var(--surface);
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

.speed-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.speed-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.speed-btns {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.speed-btn {
  margin: 0;
  padding: 0 22rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  background: var(--surface);
  color: var(--text-primary);
  border: 1rpx solid var(--border);
}

.speed-btn.on {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(22, 119, 255, 0.08);
}

.theme-dark .speed-btn.on {
  background: rgba(64, 150, 255, 0.12);
}

.canvas-wrap {
  position: relative;
  width: 100%;
  margin: 0 auto 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid var(--border);
  background: var(--surface);
}

.snake-canvas {
  display: block;
  width: 100%;
  height: 100%;
}

.countdown-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
}

.countdown-num {
  font-size: 120rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.35);
}

.countdown-hint {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
}

.swipe-layer {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
}

/* 十字方向键：圆角胶囊 + 轻微阴影 */
.dpad-wrap {
  margin-bottom: 24rpx;
}

.dpad-cross {
  display: grid;
  grid-template-columns: 1fr 96rpx 1fr;
  grid-template-rows: 96rpx 96rpx 96rpx;
  gap: 12rpx;
  justify-items: center;
  align-items: center;
  max-width: 360rpx;
  margin: 0 auto;
}

.dpad-spacer {
  width: 100%;
}

.pad-cell {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(165deg, var(--surface) 0%, rgba(22, 119, 255, 0.06) 100%);
  border: 2rpx solid rgba(22, 119, 255, 0.35);
  box-shadow: 0 6rpx 20rpx rgba(22, 119, 255, 0.12);
}

.theme-dark .pad-cell {
  background: linear-gradient(165deg, #1f1f1f 0%, rgba(64, 150, 255, 0.1) 100%);
  border-color: rgba(105, 177, 255, 0.45);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.45);
}

.pad-cell:active {
  opacity: 0.82;
  transform: scale(0.96);
}

.pad-arrow {
  font-size: 40rpx;
  color: var(--accent);
  font-weight: 600;
  line-height: 1;
}

.pad-center {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  border: 1rpx dashed var(--border);
  opacity: 0.45;
}

.toolbar {
  margin-bottom: 16rpx;
}

.wide {
  width: 100%;
  margin: 0;
}

.ghost {
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

/* 结束：底部提示条（非全屏） */
.game-over-tip {
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.theme-dark .game-over-tip {
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.35);
}

.tip-main {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 12rpx 20rpx;
  margin-bottom: 8rpx;
}

.tip-badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(22, 119, 255, 0.12);
  color: var(--accent);
  font-weight: 600;
}

.tip-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.tip-score {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
}

.tip-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.tip-hint {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.tip-actions {
  display: flex;
  gap: 16rpx;
}

.tip-btn {
  flex: 1;
  margin: 0;
  line-height: 80rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.tip-btn.primary {
  background: var(--accent);
  color: #fff;
  border: none;
}

.tip-btn.ghost {
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 48rpx;
  box-sizing: border-box;
}

.mask-card {
  width: 100%;
  max-width: 560rpx;
  background: var(--surface);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  border: 1rpx solid var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.mask-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.mask-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

.primary-btn {
  width: 100%;
  margin: 0;
  background: var(--accent);
  color: #fff;
  border: none;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.footer-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-top: auto;
}
