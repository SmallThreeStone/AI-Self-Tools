.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.card-title.tight {
  margin-bottom: 0;
}

.usage-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.usage-info {
  font-size: 28rpx;
  color: var(--accent);
}

.usage-scope {
  display: block;
  font-size: 22rpx;
  line-height: 1.55;
  margin-bottom: 16rpx;
}

.primary {
  margin-top: 12rpx;
  background: var(--accent);
  color: #fff;
}

.ghost {
  margin-top: 12rpx;
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

.gap-top {
  margin-top: 28rpx;
}

.line {
  display: block;
  font-size: 26rpx;
  margin-bottom: 8rpx;
  color: var(--text-primary);
}

.muted {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.import-area {
  width: 100%;
  min-height: 160rpx;
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.danger-zone .danger {
  background: #ff4d4f;
  color: #fff;
}

.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.nav-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

.nav-arrow {
  font-size: 36rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.nav-hover {
  opacity: 0.75;
}

.block-gap {
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.55;
}

.backup-line {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.55;
  margin-bottom: 6rpx;
}

.import-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.half {
  flex: 1;
  margin: 0;
}

.danger-outline {
  background: #fff;
  color: #cf1322;
  border: 1rpx solid #ffccc7;
}

.footnote {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
}
