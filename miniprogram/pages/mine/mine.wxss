.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
  box-sizing: border-box;
}

.page.with-tab-bar {
  padding-bottom: calc(48rpx + 108rpx + env(safe-area-inset-bottom));
}

.card {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mini {
  margin: 0;
}

.primary {
  margin-top: 12rpx;
  background: var(--accent);
  color: #fff;
}

.ghost {
  margin-top: 12rpx;
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

.gap-top {
  margin-top: 28rpx;
}

.line {
  display: block;
  font-size: 26rpx;
  margin-bottom: 8rpx;
  color: var(--text-primary);
}

.muted {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.import-area {
  width: 100%;
  min-height: 160rpx;
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.danger-zone .danger {
  background: #ff4d4f;
  color: #fff;
}

.footer {
  text-align: center;
  font-size: 22rpx;
  margin-top: 24rpx;
}

.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.nav-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

.nav-arrow {
  font-size: 36rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.nav-hover {
  opacity: 0.75;
}

.block-gap {
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.55;
}

.strong-inline {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.footnote-small {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.feedback-btn {
  margin-top: 8rpx;
}

.theme-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.theme-btn.on {
  background: var(--accent);
  color: #fff;
}

.strong {
  font-weight: 600;
  color: var(--text-primary);
}
