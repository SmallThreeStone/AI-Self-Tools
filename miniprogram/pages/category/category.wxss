.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-bottom: calc(108rpx + env(safe-area-inset-bottom));
}

.layout {
  flex: 1;
  display: flex;
  flex-direction: row;
  min-height: 0;
}

.sidebar {
  width: 200rpx;
  background: var(--surface);
  border-right: 1rpx solid var(--border);
  height: 100%;
}

.cat-item {
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border-left: 6rpx solid transparent;
}

.cat-item.active {
  border-left-color: var(--accent);
  color: var(--accent);
}

.cat-icon {
  font-size: 36rpx;
}

.cat-name {
  font-size: 22rpx;
  text-align: center;
  color: var(--text-primary);
}

.cat-item.active .cat-name {
  color: var(--accent);
  font-weight: 600;
}

.main {
  flex: 1;
  padding: 16rpx 24rpx 48rpx;
  box-sizing: border-box;
  height: 100%;
}

.main-head {
  margin-bottom: 16rpx;
}

.main-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-right: 12rpx;
}

.main-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}
