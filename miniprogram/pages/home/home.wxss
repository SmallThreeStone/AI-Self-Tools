.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.page.with-tab-bar {
  padding-bottom: calc(48rpx + 108rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  background: var(--surface);
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
  border: 1rpx solid var(--border);
}

.clear {
  font-size: 26rpx;
  color: var(--accent);
}

.search-tip {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin: -12rpx 8rpx 16rpx;
  line-height: 1.5;
}

.search-extra {
  margin-bottom: 28rpx;
}

.chip-row {
  margin-bottom: 20rpx;
}

.chip-row--inline {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
}

.chip-row--stack .chip-label {
  margin-bottom: 0;
}

.chip-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.chip-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.chip-label--side {
  flex-shrink: 0;
  margin-bottom: 0;
  padding-top: 12rpx;
  line-height: 1.3;
}

.chip-label--flush {
  margin-bottom: 0;
}

.chip-head .chip-label {
  margin-bottom: 0;
}

.chip-clear {
  font-size: 22rpx;
  color: var(--accent);
}

.chips {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  align-content: flex-start;
  gap: 12rpx;
}

.chip {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  color: var(--text-primary);
  box-sizing: border-box;
  flex-shrink: 0;
  max-width: 100%;
}

.chip-txt {
  font-size: 24rpx;
  line-height: 1.35;
  color: inherit;
}

.muted-chip {
  color: var(--text-secondary);
}

.section.tight {
  margin-bottom: 28rpx;
}

.cat-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.cat-chips {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0 16rpx;
}

.cat-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
}

.cat-ico {
  font-size: 28rpx;
}

.cat-txt {
  font-size: 26rpx;
  color: var(--text-primary);
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: var(--text-primary);
}

.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.empty {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 24rpx 0;
}
