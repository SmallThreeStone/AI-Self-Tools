.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
}

.hero {
  margin-bottom: 32rpx;
}

.name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.ver {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.block {
  display: block;
  font-size: 24rpx;
  line-height: 1.65;
}

.muted {
  color: var(--text-secondary);
}

.link-card {
  display: block;
  margin-top: 36rpx;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
  position: relative;
}

.link-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.link-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  padding-right: 40rpx;
}

.link-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.link-hover {
  opacity: 0.85;
}
