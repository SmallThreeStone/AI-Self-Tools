.page {
  min-height: 100vh;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

.hero {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

.desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

.hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}
