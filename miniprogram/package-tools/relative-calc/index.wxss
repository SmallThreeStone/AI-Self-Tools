.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 16rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.search {
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 16rpx;
  background: var(--surface);
  margin-bottom: 12rpx;
}

.list {
  flex: 1;
  height: 0;
}

.item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.q {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.a {
  font-size: 26rpx;
  color: var(--accent);
}

.foot {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  line-height: 1.5;
}
