.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.tip {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.add {
  margin-bottom: 24rpx;
  background: var(--accent);
  color: #fff;
}

.card {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-preview {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-ts {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.empty {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 48rpx 0;
  text-align: center;
}

.title-inp {
  width: 100%;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
  box-sizing: border-box;
}

.body-inp {
  width: 100%;
  min-height: 320rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
  box-sizing: border-box;
}

.row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.primary.sm {
  flex: 1;
  min-width: 160rpx;
  background: var(--accent);
  color: #fff;
}

.ghost {
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

.danger {
  background: #fff1f0;
  color: #cf1322;
  border: 1rpx solid #ffa39e;
}
