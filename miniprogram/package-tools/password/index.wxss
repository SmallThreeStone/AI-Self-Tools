.page {
  min-height: 100vh;
  padding: 32rpx;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.input {
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 16rpx;
  background: var(--surface);
}

.checks {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
}

.chip.on {
  border-color: var(--accent);
  color: var(--accent);
}

.primary {
  background: var(--accent);
  color: #fff;
  margin-bottom: 24rpx;
}

.out {
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
}

.pwd {
  font-size: 28rpx;
  word-break: break-all;
}

.ghost {
  margin-top: 16rpx;
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}
