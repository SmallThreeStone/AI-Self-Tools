.page {
  min-height: 100vh;
  padding: 24rpx;
}

.modes {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.chip {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.chip.on {
  border-color: var(--accent);
  color: var(--accent);
  font-weight: 600;
}

.primary {
  background: var(--accent);
  color: #fff;
}

.card {
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  font-size: 30rpx;
  line-height: 1.65;
}
