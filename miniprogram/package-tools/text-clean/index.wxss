.page {
  min-height: 100vh;
  padding: 24rpx;
}

.tip {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.area {
  width: 100%;
  min-height: 280rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
  box-sizing: border-box;
}

.stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 32rpx;
  margin: 20rpx 0;
  font-size: 26rpx;
  color: var(--text-primary);
}

.row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.btn {
  flex: 1;
  margin: 0;
}

.btn.ghost {
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

.btn.danger {
  background: #fff1f0;
  color: #cf1322;
}
