.page {
  min-height: 100vh;
  padding: 24rpx;
}

.tip {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.area {
  width: 100%;
  min-height: 220rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
  box-sizing: border-box;
}

.picker {
  margin: 20rpx 0;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
}

.primary {
  background: var(--accent);
  color: #fff;
}

.result {
  margin-top: 28rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
}

.line {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 12rpx;
  color: var(--text-primary);
}

.ghost {
  margin-top: 20rpx;
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}
