.page {
  min-height: 100vh;
  padding: 24rpx;
}

.hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.area {
  width: 100%;
  min-height: 220rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
  margin-bottom: 24rpx;
}

.primary {
  background: var(--accent);
  color: #fff;
}

.result-box {
  margin-top: 40rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
}

.label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.result {
  display: block;
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
}
