.page {
  min-height: 100vh;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.coin {
  font-size: 160rpx;
  line-height: 1;
}

.coin.spin {
  opacity: 0.6;
}

.result {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--accent);
}

.hint {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.btn.primary {
  width: 100%;
  max-width: 480rpx;
  background: var(--accent);
  color: #fff;
}
