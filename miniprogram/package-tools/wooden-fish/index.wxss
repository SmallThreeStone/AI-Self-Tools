.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.merit {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--accent);
}

.sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.fish-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 360rpx;
}

.fish {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--surface), rgba(22, 119, 255, 0.12));
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.08s ease-out;
}

.fish.bash {
  transform: scale(0.92);
}

.emoji {
  font-size: 140rpx;
}

.hint {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.ghost {
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}
