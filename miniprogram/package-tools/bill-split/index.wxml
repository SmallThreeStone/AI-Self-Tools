<view class="page {{themeClass}}">
  <view class="field">
    <text class="label">总金额（元）</text>
    <input class="input" type="digit" placeholder="例如 268" value="{{total}}" bindinput="onTotal" />
  </view>
  <view class="field">
    <text class="label">人数</text>
    <input class="input" type="number" placeholder="例如 5" value="{{people}}" bindinput="onPeople" />
  </view>

  <view class="card">
    <text class="big">每人 ¥ {{perPerson}}</text>
  </view>

  <button class="primary" bindtap="onCopy">复制结算文案</button>
</view>
