.page {
  min-height: 100vh;
  padding: 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.input {
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx;
  background: var(--surface);
}

.card {
  margin: 32rpx 0;
  padding: 28rpx;
  border-radius: 16rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
}

.big {
  font-size: 40rpx;
  font-weight: 600;
}

.primary {
  background: var(--accent);
  color: #fff;
}
