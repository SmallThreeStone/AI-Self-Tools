.page {
  min-height: 100vh;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.clock {
  font-size: 96rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  color: var(--text-primary);
}

.label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.sys-hint {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.55;
  text-align: center;
  padding: 0 16rpx;
  margin-top: -8rpx;
}

.picker {
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  color: var(--text-primary);
}

.actions {
  margin-top: 48rpx;
  width: 100%;
  display: flex;
  gap: 24rpx;
}

.btn {
  flex: 1;
}

.primary {
  background: var(--accent);
  color: #fff;
}

.ghost {
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}
