.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.input {
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx;
  background: var(--surface);
}

.seg {
  display: flex;
  gap: 16rpx;
}

.seg-btn {
  flex: 1;
  background: var(--surface);
  border: 1rpx solid var(--border);
  color: var(--text-primary);
}

.seg-btn.on {
  border-color: var(--accent);
  color: var(--accent);
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.tag.on {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(22, 119, 255, 0.08);
}

.card {
  margin-top: 16rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
}

.k {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.v {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--accent);
  margin-top: 8rpx;
}

.row2 {
  margin-top: 28rpx;
}

.unit {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-secondary);
}

.foot {
  display: block;
  margin-top: 24rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}
