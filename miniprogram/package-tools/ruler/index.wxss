.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.calib .hint {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.card-bar-wrap {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  min-height: 120rpx;
  margin-bottom: 16rpx;
}

.card-bar {
  height: 56rpx;
  background: #ffffff;
  border: 2rpx solid var(--accent);
  border-radius: 8rpx;
}

.primary {
  margin-top: 24rpx;
  background: var(--accent);
  color: #fff;
}

.meta {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.track-wrap {
  overflow-x: hidden;
}

.track {
  position: relative;
  height: 120rpx;
  margin-top: 8rpx;
}

.tick {
  position: absolute;
  bottom: 0;
  width: 2rpx;
  margin-left: -1rpx;
  height: 24rpx;
  background: var(--border);
}

.tick.major {
  height: 48rpx;
  background: var(--accent);
}

.lbl {
  position: absolute;
  bottom: 52rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.ghost {
  margin-top: 32rpx;
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}
