.page {
  min-height: 100vh;
  padding: 32rpx;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tab {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  color: var(--text-secondary);
}

.tab.active {
  border-color: var(--accent);
  color: var(--accent);
  font-weight: 600;
}

.hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.input {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.lines {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid var(--border);
}

.line {
  display: block;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}
