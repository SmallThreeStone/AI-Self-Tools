.page {
  min-height: 100vh;
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.form {
  margin-bottom: 16rpx;
}

.inp {
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  background: var(--surface);
}

.primary {
  background: var(--accent);
  color: #fff;
}

.list {
  flex: 1;
  height: 0;
}

.card {
  position: relative;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
}

.meta {
  margin-bottom: 8rpx;
}

.t {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.d {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.lab {
  font-size: 28rpx;
  color: var(--accent);
}

.del {
  position: absolute;
  right: 20rpx;
  top: 24rpx;
  font-size: 24rpx;
  color: #ff4d4f;
}
