.page {
  min-height: 100vh;
  padding: 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.input {
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx;
  background: var(--surface);
}

.card {
  margin-top: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
}

.bmi {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--accent);
}

.level {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}
