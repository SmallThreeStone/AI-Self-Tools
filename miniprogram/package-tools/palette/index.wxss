.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.swatch {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
}

.hex {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.mini {
  font-size: 26rpx;
  padding: 12rpx 28rpx;
}

.mini.primary {
  background: var(--accent);
  color: #fff;
}

.sliders {
  margin-top: 32rpx;
}

.lab {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.fav-block {
  margin-top: 40rpx;
}

.fav-title {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.fav-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.fav-item {
  position: relative;
}

.fav-dot {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
}

.fav-x {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 28rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  border-radius: 50%;
}
