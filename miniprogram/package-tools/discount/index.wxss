.page {
  min-height: 100vh;
  padding: 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.input {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx;
}

.result {
  margin-top: 48rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
}

.line {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
}

.line.sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-secondary);
}
