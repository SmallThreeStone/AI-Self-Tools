.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.field {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--page-bg);
  font-size: 28rpx;
}

.area {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--page-bg);
  font-size: 28rpx;
}

.seg {
  display: flex;
  gap: 16rpx;
}

.seg-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.seg-item.on {
  border-color: var(--accent);
  color: var(--accent);
  font-weight: 600;
}

.hint {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-top: 8rpx;
}

.primary {
  width: 100%;
  margin: 0;
  background: var(--accent);
  color: #fff;
  border: none;
  line-height: 96rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}
