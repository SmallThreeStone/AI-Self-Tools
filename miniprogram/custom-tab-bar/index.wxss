.tab-host {
  --tab-frost-light: rgba(255, 255, 255, 0.78);
  --tab-frost-dark: rgba(28, 28, 28, 0.82);
  --tab-border-light: rgba(0, 0, 0, 0.06);
  --tab-border-dark: rgba(255, 255, 255, 0.08);
  --tab-pill-active-light: rgba(22, 119, 255, 0.14);
  --tab-pill-active-dark: rgba(64, 150, 255, 0.22);
  --tab-text: #666666;
  --tab-text-active: #1677ff;
}

.tab-host.theme-dark {
  --tab-text: #a3a3a3;
  --tab-text-active: #69b1ff;
}

.tab-bar-blur {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  padding-top: 12rpx;
  background: var(--tab-frost-light);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border-top: 1rpx solid var(--tab-border-light);
}

.theme-dark .tab-bar-blur {
  background: var(--tab-frost-dark);
  border-top-color: var(--tab-border-dark);
}

.tab-bar-inner {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  justify-content: space-around;
  padding-top: 4rpx;
  padding-bottom: 8rpx;
}

.safe-bottom {
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.tab-pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 10rpx 28rpx 12rpx;
  border-radius: 999rpx;
  max-width: 100%;
  box-sizing: border-box;
}

.tab-item--active .tab-pill {
  background: var(--tab-pill-active-light);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  box-shadow: 0 1rpx 8rpx rgba(22, 119, 255, 0.12);
}

.theme-dark .tab-item--active .tab-pill {
  background: var(--tab-pill-active-dark);
  box-shadow: 0 1rpx 12rpx rgba(0, 0, 0, 0.35);
}

.tab-ico {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.theme-dark .tab-item:not(.tab-item--active) .tab-ico {
  opacity: 0.9;
}

.tab-txt {
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--tab-text);
}

.tab-item--active .tab-txt {
  color: var(--tab-text-active);
  font-weight: 600;
}
