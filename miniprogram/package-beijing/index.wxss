.page {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.tabs {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  background: #fff;
  border-bottom: 1rpx solid #e8e8e8;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  display: inline-flex;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  color: #666;
}

.tab--on {
  color: #1677ff;
  font-weight: 600;
  border-bottom: 4rpx solid #1677ff;
  margin-bottom: -2rpx;
}

.panel {
  height: calc(100vh - 120rpx);
  padding: 24rpx;
  box-sizing: border-box;
}

.panel--map {
  padding-top: 16rpx;
}

.banner {
  background: linear-gradient(135deg, #1a2332 0%, #2d3a4d 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.banner-title {
  display: block;
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
}

.banner-sub {
  display: block;
  color: rgba(255, 255, 255, 0.75);
  font-size: 24rpx;
  margin-top: 12rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card.warn {
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  color: #8c5a00;
  font-size: 26rpx;
}

.card-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.day-tag {
  background: #1677ff;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.line {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  margin-top: 8rpx;
}

.h3 {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.h3.mt {
  margin-top: 28rpx;
}

.mini {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.table-wrap {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}

.tr {
  display: flex;
  flex-direction: row;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  color: #444;
}

.tr.th {
  background: #fafafa;
  font-weight: 600;
  color: #1677ff;
}

.tr:last-child {
  border-bottom: none;
}

.td {
  flex: 1;
  word-break: break-all;
}

.td--wide {
  flex: 2.2;
  white-space: pre-line;
}

.td--price {
  flex: 1.3;
  font-size: 22rpx;
  color: #666;
}

.strong {
  font-weight: 700;
  color: #1a1a1a;
}

.kv {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-top: 10rpx;
  line-height: 1.5;
}

.kv.price {
  color: #00a854;
  font-weight: 600;
  margin-top: 16rpx;
}

.btn-ghost {
  margin-top: 16rpx;
  background: #f5f5f5;
  color: #1677ff;
}

.map {
  width: 100%;
  height: 480rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.seg-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.seg-row:last-of-type {
  border-bottom: none;
}

.seg-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.seg-label {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.seg-sw {
  transform: scale(0.85);
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn {
  background: #1677ff;
  color: #fff;
}

.btn--ghost {
  background: #f0f0f0;
  color: #333;
}

.poi-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 12rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.poi-row:active {
  background: #f9f9f9;
}

.poi-num {
  width: 48rpx;
  font-size: 32rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.poi-mid {
  flex: 1;
  min-width: 0;
}

.poi-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.poi-note {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.poi-arrow {
  color: #ccc;
  font-size: 40rpx;
  padding-left: 12rpx;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.inp {
  background: #f5f6f8;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.sum {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #e6f4ff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1677ff;
}

.sum-per {
  display: block;
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #00a854;
}

.hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888;
}

.link-btn {
  margin-bottom: 16rpx;
  background: #fff;
  border: 1rpx solid #d9d9d9;
  color: #1677ff;
  font-size: 28rpx;
}

.link-btn::after {
  border: none;
}

/* —— 向导首页 —— */
.hero {
  background: linear-gradient(145deg, #0d3a5c 0%, #1677ff 48%, #69c0ff 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(22, 119, 255, 0.25);
}

.hero--sub {
  background: linear-gradient(135deg, #1a2332 0%, #2d3a4d 100%);
  box-shadow: none;
  padding: 28rpx;
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 0.12em;
  margin-bottom: 8rpx;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 0.02em;
}

.hero-title--sm {
  font-size: 34rpx;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.92);
}

.card--phase {
  padding-bottom: 20rpx;
}

.card-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.phase-strip {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 4rpx 0;
}

.phase-strip--pad {
  margin-bottom: 20rpx;
}

.phase-chip {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #444;
  background: #f5f6f8;
  border: 2rpx solid transparent;
}

.phase-chip--on {
  background: #e6f4ff;
  color: #1677ff;
  font-weight: 700;
  border-color: #1677ff;
}

.guide-card {
  border-left: 8rpx solid #1677ff;
}

.guide-head {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.35;
}

.guide-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.55;
}

.guide-bullet {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #333;
  padding-left: 4rpx;
}

.btn-solid {
  margin-top: 24rpx;
  width: 100%;
  background: #1677ff;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx;
  padding: 22rpx 0;
}

.btn-solid::after {
  border: none;
}

.tip-soft {
  display: block;
  margin-top: 16rpx;
  margin-bottom: 0;
}

.quick-strip {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  margin-top: 8rpx;
}

.quick-btn {
  display: inline-flex;
  margin-right: 12rpx;
  margin-top: 8rpx;
  padding: 14rpx 22rpx;
  font-size: 24rpx;
  background: #f0f5ff;
  color: #1677ff;
  border-radius: 999rpx;
  border: 1rpx solid #adc6ff;
}

.quick-btn::after {
  border: none;
}

.check-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 22rpx 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.check-row:active {
  opacity: 0.85;
}

.check-ico {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 2rpx solid #d9d9d9;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.check-ico--on {
  background: #52c41a;
  border-color: #52c41a;
}

.check-txt {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.family-tip {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.55;
  background: #fafafa;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.detail {
  display: block;
  font-size: 24rpx;
  color: #888;
  line-height: 1.55;
  margin-top: 10rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #e8e8e8;
}

.hotel-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.hotel-actions .btn-ghost {
  margin-top: 0;
}

.call-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.call-btn {
  flex: 1;
  background: #fff1f0;
  color: #cf1322;
  font-size: 28rpx;
  font-weight: 600;
  border: 1rpx solid #ffa39e;
  border-radius: 12rpx;
}

.call-btn::after {
  border: none;
}
