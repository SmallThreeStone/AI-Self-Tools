.page {
  min-height: 100vh;
  padding: 16rpx 24rpx 32rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.lab {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
}

.dot.blue {
  background: #1677ff;
}

.dot.black {
  background: #222222;
}

.dot.red {
  background: #ff4d4f;
}

.dot.on {
  box-shadow: 0 0 0 3rpx var(--accent);
}

.mini.plain {
  margin-left: auto;
  background: var(--surface);
  color: var(--text-primary);
}

.board {
  width: 100%;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: #fff;
  touch-action: none;
}

.primary {
  margin-top: 20rpx;
  background: var(--accent);
  color: #fff;
}

.hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}
