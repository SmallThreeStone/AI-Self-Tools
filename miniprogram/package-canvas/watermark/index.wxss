.page {
  min-height: 100vh;
  padding: 24rpx;
}

.primary {
  background: var(--accent);
  color: #fff;
  margin-bottom: 20rpx;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.input {
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 16rpx;
  background: var(--surface);
}

.canvas {
  margin: 16rpx auto;
  background: #111;
  display: block;
}

.ghost {
  margin-top: 12rpx;
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

.hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}
