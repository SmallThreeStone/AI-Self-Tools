.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sheet {
  width: 100%;
  max-height: 78vh;
  overflow-y: auto;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #ffffff;
  color: #1f1f1f;
}

.emoji {
  display: block;
  font-size: 56rpx;
  text-align: center;
  margin-bottom: 12rpx;
}

.name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
}

.desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #434343;
}

.tags,
.perm,
.last {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #595959;
}

.last {
  color: #1677ff;
}

.hint {
  display: block;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #8c8c8c;
}

.btn-row {
  margin-top: 28rpx;
}

.btn-row.dual {
  display: flex;
  gap: 16rpx;
}

.btn {
  margin: 0;
  font-size: 28rpx;
}

.btn.primary {
  background: #1677ff;
  color: #fff;
}

.btn.ghost {
  flex: 1;
  background: #fff;
  color: #1677ff;
  border: 1rpx solid #1677ff;
}

.close-link {
  display: block;
  text-align: center;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #8c8c8c;
}
